# Copy to .env and fill in. Never commit the real .env.

# Secret used to sign auth tokens. Generate a long random string for production.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Database connection.
# Local dev (SQLite): file:./kma.db
# Production (Postgres / Neon): postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URI=file:./kma.db

# ---------------------------------------------------------------------------
# Optional: persistent media storage for uploaded images & PDFs.
# Leave blank to use local disk (fine for local dev; NOT persistent on Vercel).
# Set these to enable S3 or any S3-compatible store (AWS S3, Cloudflare R2, etc.).
# ---------------------------------------------------------------------------
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Only for S3-compatible providers (e.g. Cloudflare R2). Leave blank for AWS S3.
S3_ENDPOINT=
