# Copy to .env and fill in. Never commit the real .env.

# Secret used to sign auth tokens. Generate a long random string for production.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Optional: provision a Super Admin login automatically on first boot, so you
# have a guaranteed admin account. Set these in the host (e.g. Railway), deploy,
# then log in at /admin with this email + password. Created once; change the
# password in the admin afterwards if you like.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# Database connection.
# Local dev (SQLite): file:./kma.db
# Production (Postgres / Neon): postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URI=file:./kma.db

# ---------------------------------------------------------------------------
# Multi-platform (mobile apps, PWA, mosque screens).
# ---------------------------------------------------------------------------
# Public URL of the deployed site, e.g. https://kingstonmosque.org
SERVER_URL=
# Comma-separated origins allowed to call the API (apps/PWA/screens). Leave
# blank to allow all origins ("*"); app-facing data is public read-only.
# Example: https://kingstonmosque.org,https://app.kingstonmosque.org
CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Optional: persistent media storage for uploaded images & PDFs.
# Leave blank to use local disk (fine for local dev; NOT persistent on Vercel).
# Set these to enable S3 or any S3-compatible store (AWS S3, Cloudflare R2, etc.).
# ---------------------------------------------------------------------------
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Only for S3-compatible providers (e.g. Cloudflare R2). Leave blank for AWS S3.
S3_ENDPOINT=

# ---------------------------------------------------------------------------
# Optional: email delivery (contact-form notifications). Without these, contact
# messages are still saved in the admin under "Contact Messages".
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@kingstonmosque.org
# Where contact-form notifications are sent (defaults to SMTP_FROM):
CONTACT_TO=info@kingstonmosque.org

# ---------------------------------------------------------------------------
# Optional: Broadcast Center channels (admin "Broadcast" → compose & send).
# Each channel activates only when its vars are set; unset channels are skipped.
# Email uses the SMTP_* settings above. See docs/BROADCAST.md.
# ---------------------------------------------------------------------------
# Telegram — posts into your mosque group/channel (add the bot as admin first).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# WhatsApp Business Cloud API — broadcasts to opted-in subscribers.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# WhatsApp GROUP posting via the self-hosted gateway (whatsapp-gateway/).
# When these are set, broadcasts post into the actual group(s) instead of the
# Cloud API. WHATSAPP_GROUP_IDS is comma-separated (e.g. 12036...@g.us,12036...@g.us).
WHATSAPP_GATEWAY_URL=
WHATSAPP_GATEWAY_SECRET=
WHATSAPP_GROUP_IDS=
# Facebook Page + Instagram (Meta Graph API). INSTAGRAM_TOKEN falls back to the
# Facebook Page token if blank. Instagram posts require an image.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_TOKEN=

# In-app donations (Apple Pay / Google Pay / cards / monthly) via Stripe
# Checkout. Create a key at dashboard.stripe.com → Developers → API keys.
# Absent = the app falls back to the external giving link / bank details.
STRIPE_SECRET_KEY=
