# Copy to .env and fill in. Never commit the real .env.

# Secret used to sign auth tokens. Generate a long random string for production.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Database connection.
# Local dev (SQLite): file:./kma.db
# Production (Postgres / Neon): postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URI=file:./kma.db
